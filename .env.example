# Токен бота (допустимо имя TELEGRAM_TOKEN)
BOT_TOKEN=your_bot_token

# --- ЮKassa (опционально). Лучше эти имена — не пересекаются с чужим SECRET_KEY в Windows:
# YOOKASSA_SHOP_ID=123456
# YOOKASSA_SECRET_KEY=test_...
# Альтернатива: SHOP_ID и SECRET_KEY (значения из .env перекрывают системные переменные).
# В личном кабинете ЮKassa укажите URL webhook: https://ВАШ_ДОМЕН/yookassa-webhook (только HTTPS в продакшене).
# Страница возврата после оплаты (HTTPS)
# YOOKASSA_RETURN_URL=https://example.com/thanks
# Порт HTTP-сервера webhook в том же процессе, что и бот (см. bot.py)
# WEBHOOK_PORT=8080
# WEBHOOK_HOST=0.0.0.0

ADMIN_ID=123456789

# Чат (группа или ваш user id) для заявок «подтвердить оплату». Бот должен быть в группе админом.
# 0 или пусто — слать в личку ADMIN_ID.
PAYMENTS_CHAT_ID=0

# Канал, на который пользователь ДОЛЖЕН быть подписан для записи
CHANNEL_ID=-1001234567890
CHANNEL_LINK=https://t.me/your_channel

# Канал, куда бот публикует расписание (можно тот же, что и CHANNEL_ID)
SCHEDULE_CHANNEL_ID=-1001234567890

# Реквизиты для оплаты (можно переносы строк через \n)
PAYMENT_DETAILS=Перевод на карту: 0000 0000 0000 0000\nПолучатель: Studio Name

# Картинка на экранах с реквизитами и оплатой (запись на студию, текст, бит). Оставьте пустым — только текст.
PAYMENT_PHOTO_PATH=C:\Users\zaggo\recording_studio_bot_v2\Pictures\payment.jpg

# Часовой пояс для напоминаний APScheduler
TZ=Europe/Moscow

# Путь к SQLite базе (можно оставить по умолчанию)
DB_PATH=studio_bot.db

# --- Изображения (локальные пути на вашем ПК) ---
MAIN_MENU_PHOTO_PATH=C:\path\to\main_menu.jpg
PRICES_PHOTO_PATH=C:\path\to\prices.jpg

# Экраны тарифов (пусто — без смены картинки, только текст/подпись)
TARIFF_CATEGORY_PHOTO_PATH=C:\path\to\tariff_choose_night_day.jpg
TARIFF_NIGHT_PHOTO_PATH=C:\path\to\tariff_night.jpg
TARIFF_DAY_PHOTO_PATH=C:\path\to\tariff_day.jpg

# --- Оборудование (текст + альбом фото) ---
EQUIPMENT_TITLE=Оборудование и Фото Студии
EQUIPMENT_TEXT=Наша студия звукозаписи — уютное пространство для записи голоса, подкастов и музыки.
MICROPHONE_NAME=Микрофон (модель)
AUDIACARD_NAME=Аудиокарта (модель)
HEADPHONES_NAME=Наушники (модель)
MONITORS_NAME=Мониторы (модель)

# Пути к фото для альбома (можно оставить пустым, если не нужно)
EQUIPMENT_PHOTO_MICROPHONE_PATH=C:\path\to\mic.jpg
EQUIPMENT_PHOTO_AUDIOCARD_PATH=C:\path\to\audio.jpg
EQUIPMENT_PHOTO_HEADPHONES_PATH=C:\path\to\headphones.jpg
EQUIPMENT_PHOTO_MONITORS_PATH=C:\path\to\monitors.jpg
EQUIPMENT_PHOTO_GENERAL_1_PATH=C:\path\to\general1.jpg
EQUIPMENT_PHOTO_GENERAL_2_PATH=C:\path\to\general2.jpg

# --- Исполнители (юзернеймы текстовика/битмейкера — НЕ клиента; из .env) ---
# Пишите без @ или с @. Дубли имён: TextMaker_Username / BeatMaker_Username тоже подхватятся.
TEXTMAKER_USERNAME=@TextMaker
BEATMAKER_USERNAME=@BeatMaker

# --- Особые тарифы (пакеты 6 / 8 / 10 / 12 ч), руб ---
# Без звукорежиссёра: N × HOURLY_BASE_NO_ENGINEER, если TARIFF_* не заданы явно
HOURLY_BASE_NO_ENGINEER=1000

# Ночная запись, без звукаря (интервал с 00:00)
TARIFF_NIGHT_6H=6000
TARIFF_NIGHT_8H=8000
TARIFF_NIGHT_10H=10000
TARIFF_NIGHT_12H=12000

# Дневная запись, без звукаря (старт 09:00 или 12:00)
TARIFF_DAY_6H=6000
TARIFF_DAY_8H=8000
TARIFF_DAY_10H=10000
TARIFF_DAY_12H=12000

# Со звукорежиссёром: N × HOURLY_BASE_WITH_ENGINEER, если TARIFF_*_ENGINEER не заданы
HOURLY_BASE_WITH_ENGINEER=1800

TARIFF_NIGHT_6H_ENGINEER=10800
TARIFF_NIGHT_8H_ENGINEER=14400
TARIFF_NIGHT_10H_ENGINEER=18000
TARIFF_NIGHT_12H_ENGINEER=21600

TARIFF_DAY_6H_ENGINEER=10800
TARIFF_DAY_8H_ENGINEER=14400
TARIFF_DAY_10H_ENGINEER=18000
TARIFF_DAY_12H_ENGINEER=21600
